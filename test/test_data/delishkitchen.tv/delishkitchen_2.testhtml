2個",link:"\u002Fcategories\u002F2738"},{ingredient_id:75,name:"しめじ",servings1:"大1パック(約150g)",link:"\u002Fcategories\u002F4254"},{ingredient_id:30760,name:"枝豆(冷凍)",servings1:"200g",link:"\u002Fcategories\u002F5089"},{ingredient_id:72,name:s,servings1:Y,link:b},{ingredient_id:6108,name:"貝割れ菜",servings1:"適宜",link:"\u002Fsearch?q=かいわれ"},{ingredient_id:3718,name:p,servings1:bb,link:"\u002Fsearch?q=いりごま"}]},{id:10768,name:"＜煮汁＞",recipe_ingredients:[{ingredient_id:6770,name:"だし汁",servings1:"3\u002F4カップ",link:b},{ingredient_id:2653,name:q,servings1:"大さじ1\u002F2",link:b},{ingredient_id:bc,name:i,servings1:Y,link:b},{ingredient_id:30,name:y,servings1:Y,link:b}]},{id:10769,name:"＜すし酢＞",recipe_ingredients:[{ingredient_id:291,name:r,servings1:"大さじ2",link:b},{ingredient_id:bc,name:i,servings1:"小さじ2",link:b},{ingredient_id:bd,name:h,servings1:bb,link:b}]}],recipe_tags:[{recipe_id:g,recipe_id_str:g,tag_id:f,tag_name:W},{recipe_id:g,recipe_id_str:g,tag_id:700,tag_name:"おもてなし"},{recipe_id:g,recipe_id_str:g,tag_id:Z,tag_name:D},{recipe_id:g,recipe_id_str:g,tag_id:_,tag_name:$},{recipe_id:g,recipe_id_str:g,tag_id:2829,tag_name:"海藻・乾物・こんにゃく"},{recipe_id:g,recipe_id_str:g,tag_id:be,tag_name:bf},{recipe_id:g,recipe_id_str:g,tag_id:17212,tag_name:"ホームパーティー"},{recipe_id:g,recipe_id_str:g,tag_id:J,tag_name:K},{recipe_id:g,recipe_id_str:g,tag_id:17499,tag_name:"プレミアム用ブランド"},{recipe_id:g,recipe_id_str:g,tag_id:aa,tag_name:ab},{recipe_id:g,recipe_id_str:g,tag_id:18234,tag_name:s},{recipe_id:g,recipe_id_str:g,tag_id:18376,tag_name:"お酢"},{recipe_id:g,recipe_id_str:g,tag_id:22192,tag_name:"顆粒だし"},{recipe_id:g,recipe_id_str:g,tag_id:22196,tag_name:q}],recipe_genre:{id:bg,kind_id:432,name:"和食"},recipe_category:{id:j,kind_id:j,name:"主食"},recipe_qas:a,recipe_servings:[{recipe_id:g,recipe_id_str:g,servings:j,name:"2人分（ひじき煮は作りやすい分量）"}],recipe_steps:[{recipe_id:g,recipe_id_str:g,step:j,description:"ひじきはたっぷりの水に20分ほどつけてもどす。つめの先で切れるくらいになったら、ざるに上げてさっと洗い、水けを絞る。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F1.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F1.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:bd,description:"パプリカはへたと種を取り、縦に細切りにする。",point:"パプリカの内側のわたは、包丁できれいにそぎとったほうが黄色がきれいに映えます！",square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F2.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F2.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:f,description:"しめじは石づきを切り、小房に分ける。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F3.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F3.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:4,description:"枝豆は流水で解凍し、実を取り出す。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F4.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F4.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:bh,description:"フライパンにごま油大さじ1を強めの中火で熱し、ひじき、しめじを加えて油が回るまで炒める。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F5.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F5.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:ao,description:"煮汁の材料を加え、ときどき混ぜながら、汁けが少なくなるまで3～5分煮る。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F6.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F6.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:bg,description:"枝豆、パプリカを加え、汁けがなくなるまで1～2分煮る。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F7.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F7.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:8,description:"ボールに酢大さじ2、砂糖小さじ２、塩少々を混ぜる。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F8.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F8.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:9,description:"温かいご飯茶碗2杯分を混ぜる。7を100g分加えて混ぜる。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F9.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F9.jpg?version=1522024956"}},{recipe_id:g,recipe_id_str:g,step:l,description:"粗熱がとれたら貝割れ菜（長さ半分に切る）適宜、白いりごま少々を散らす。",point:b,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F10.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F182966866459755601\u002Fsteps\u002F10.jpg?version=1522024956"}}],nutrient:{recipe_id:g,recipe_id_str:g,items:[{name:bi,display_name:bi,icon_type:"calorie",amount:"304kcal",is_locked:c,iconComponent:"delish-icon-cooking-kcal"},{name:bj,display_name:bj,icon_type:"carbohydrate",amount:E,is_locked:c,iconComponent:"delish-icon-cooking-bread"},{name:bk,display_name:bk,icon_type:"lipid",amount:E,is_locked:c,iconComponent:"delish-icon-cooking-oil"},{name:"タンパク質",display_name:"たんぱく質",icon_type:"protein",amount:E,is_locked:c,iconComponent:"delish-icon-cooking-egg"},{name:bl,display_name:bl,icon_type:"saccharide",amount:E,is_locked:c,iconComponent:"delish-icon-cooking-candy"},{name:"塩分量",display_name:"塩分",icon_type:"salt",amount:E,is_locked:c,i