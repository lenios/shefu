:"スナップエンドウ"},{name:j},{name:l}]},{recipe_ingredients:[{name:"ミニトマト(ヘタを取り除く)"},{name:"ブロッコリー(ゆで)"},{name:"ケチャップ(後がけ用)"}]}],calorie:c,cooking_time:c,cooking_tags:a,recipe_detail:a,cooking_reports_container:a},{id:ck,id_str:ck,lead:"卵がとろける♪",title:"ビーフシチューオムライス",description:"ふわふわの半熟卵にビーフシチューをたっぷりかけていただく、ボリューム満点レシピをご紹介！お好みで仕上げに生クリームをかければおしゃれな一品に♪",state:i,state_premium:f,is_visible:d,is_favorite_free:b,advertiser:a,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F237616178762089578\u002F1.m3u8",poster_url:cl,webp_poster_url:cm},square_mp4_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F237616178762089578\u002F1.mp4",poster_url:cl,webp_poster_url:cm},ingredient_groups:[{recipe_ingredients:[{name:m},{name:"レトルトシチュー(ビーフシチュー)"},{name:j},{name:w}]},{recipe_ingredients:[{name:n},{name:r},{name:l},{name:j}]}],calorie:c,cooking_time:c,cooking_tags:a,recipe_detail:a,cooking_reports_container:a},{id:cn,id_str:cn,lead:"レンジで作る！",title:"マグカップオムライス",description:"レンジでオムライスが作れる時短レシピ！フライパンを使わないので洗い物も少なく済みます♪卵にマヨネーズを加えるとふんわりとした食感に仕上がります！急いでいるときのパパッとごはんにもおすすめの一品です。ぜひお試しください！",state:i,state_premium:f,is_visible:d,is_favorite_free:b,advertiser:a,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F152509970275893517\u002F1.m3u8",poster_url:co,webp_poster_url:cp},square_mp4_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F152509970275893517\u002F1.mp4",poster_url:co,webp_poster_url:cp},ingredient_groups:[{recipe_ingredients:[{name:m},{name:n},{name:cj},{name:"マヨネーズ"},{name:h}]},{recipe_ingredients:[{name:h},{name:w}]}],calorie:c,cooking_time:c,cooking_tags:a,recipe_detail:a,cooking_reports_container:a},{id:cq,id_str:cq,lead:"がっつり食べられる！",title:"ミルクたっぷりふわとろオムライス",description:"子供も喜ぶとろとろオムライス！\t\n休日のお昼ごはんなどにいかがですか？\t\n片栗粉を入れることで、牛乳たっぷりでも水っぽくなりません！",state:i,state_premium:f,is_visible:d,is_favorite_free:b,advertiser:a,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F1699127179