name:h}]}],calorie:c,cooking_time:c,cooking_tags:a,recipe_detail:a,cooking_reports_container:a},{id:cz,id_str:cz,lead:"お弁当にぴったり♪",title:"白うさぎのオムライス弁当",description:"オムライスの薄焼き卵に卵白とのりを使って白うさぎを作ります！\n型を使えば色々な形のオムライスが作れますよ！\n特別な日のお弁当にいかがでしょう！",state:i,state_premium:f,is_visible:d,is_favorite_free:b,advertiser:a,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F158593716271972844\u002F1.m3u8",poster_url:cA,webp_poster_url:cB},square_mp4_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F158593716271972844\u002F1.mp4",poster_url:cA,webp_poster_url:cB},ingredient_groups:[{recipe_ingredients:[{name:N},{name:"ミックスベジタブル（冷凍）"},{name:n},{name:l},{name:A},{name:q},{name:"のり"},{name:h}]},{recipe_ingredients:[{name:l},{name:v},{name:h},{name:j}]}],calorie:c,cooking_time:c,cooking_tags:a,recipe_detail:a,cooking_reports_container:a},{id:cC,id_str:cC,lead:"ふわふわとろとろ卵！",title:"マッシュルームのクリームオムライス",description:"ふわふわとろとろの卵が美味しい「マッシュルームのクリームオムライス」を紹介します。鶏肉が入ったバターライスとマッシュルームのホワイトソース、柔らかい卵の相性がとても良い組み合わせです。クリスマスのホワイトメニューにいかがでしょう♪",state:i,state_premium:f,is_visible:d,is_favorite_free:b,advertiser:a,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F187292232980627860\u002F1.m3u8",poster_url:cD,webp_poster_url:cE},square_mp4_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F187292232980627860\u002F1.mp4",poster_url:cD,webp_poster_url:cE},ingredient_groups:[{recipe_ingredients:[{name:N},{name:n},{name:"鶏もも肉　"},{name:cF},{name:o},{name:"有塩バター(バターライス用)"},{name:"塩(バターライス用)"},{name:"こしょう（バターライス用）"},{name:r},{name:"塩こしょう（卵用）"},{name:q},{name:"パセリ（刻み）"}]},{recipe_ingredients:[{name:j},{name:"薄力粉"},{name:r},{name:p},{name:v},{name:s}]}],calorie:c,cooking_time:c,cooking_tags:a,recipe_detail:a,cooking_reports_container:a},{id:cG,id_str:cG,lead:"もう包まない！",title:"ワンパンオムライス",description:"オムレツとチキンライスを別々に作るのが面倒！そんな悩みを解決するハイブリットごはんをご紹介♪チキンライスを炒めたフライパンに卵を加えて半熟状に仕上げます。",state:i,state_premium:f,is_visible:d,is_favorite_free: