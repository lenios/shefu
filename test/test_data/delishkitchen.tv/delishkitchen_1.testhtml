tchen.tv/recipe/482594657587429799/steps/1.jpg?version=1705636835","video":{"@type":"VideoObject","contentUrl":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/1.m3u8"}},{"@type":"HowToStep","text":"ベーコンは5mm幅に切る。","url":"https://delishkitchen.tv/recipes/482594657587429799#step-video-2","image":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/2.jpg?version=1705636835","video":{"@type":"VideoObject","contentUrl":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/2.m3u8"}},{"@type":"HowToStep","text":"ボウルに卵を割り入れ、牛乳を加えて混ぜる(卵液)。","url":"https://delishkitchen.tv/recipes/482594657587429799#step-video-3","image":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/3.jpg?version=1705636835","video":{"@type":"VideoObject","contentUrl":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/3.m3u8"}},{"@type":"HowToStep","text":"フライパンにオリーブオイルの半量(大さじ1/2)を入れて熱し、玉ねぎを入れてしんなりとするまで炒める。ベーコンを加えてさっと炒める。","url":"https://delishkitchen.tv/recipes/482594657587429799#step-video-4","image":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/4.jpg?version=1705636835","video":{"@type":"VideoObject","contentUrl":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/4.m3u8"}},{"@type":"HowToStep","text":"ケチャップ(大さじ1と1/2)を加えて30秒〜1分ほど炒め、ごはんを加えて炒め合わせる。塩こしょうを加えて味をととのえ、器に盛る。","url":"https://delishkitchen.tv/recipes/482594657587429799#step-video-5","image":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/5.jpg?version=1705636835","video":{"@type":"VideoObject","contentUrl":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/5.m3u8"}},{"@type":"HowToStep","text":"フライパンは洗って水気をふきとる。残りのオリーブオイル(大さじ1/2)を入れて中火で熱し、卵液を流し入れる。菜箸で大きくかき混ぜながら半熟状になるまで加熱する。","url":"https://delishkitchen.tv/recipes/482594657587429799#step-video-6","image":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/6.jpg?version=1705636835","video":{"@type":"VideoObject","contentUrl":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/6.m3u8"}},{"@type":"HowToStep","text":"5の器に卵を盛る。ケチャップをかける。","url":"https://delishkitchen.tv/recipes/482594657587429799#step-video-7","image":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/7.jpg?version=1705636835","video":{"@type":"VideoObject","contentUrl":"https://media.delishkitchen.tv/recipe/482594657587429799/steps/7.m3u8"}}],"image":"https://image.delishkitchen.tv/recipe/482594657587429799/1.jpg?version=1705849202&w=920","headline":"「のせるだけ簡単！ふわとろオムライス」をレシピ動画で！","nutrition":{"@type":"NutritionInformation","calories":"768kcal","carbohydrateContent":"92g","fatContent":"31.7g","proteinContent":"22.6g","sugarContent":"89.9g","sodiumContent":"2.4g"},"author":{"@type":"Person","name":"Minami","jobTitle":"管理栄養士","url":"https://delishkitchen.tv/food-stylists/370","image":"","description":"短大を卒業後、実務経験を積み管理栄養士を取得。デリッシュキッチンでは主に糖質オフや低カロリー、献立などプレミアムレシピの開発を担当。簡単でおいしい！毎日の食事に取り入れやすいレシピを心がけています。","affiliation":{"@type":"Organization","name":"デリッシュキッチン","url":"https://delishkitchen.tv"}},"publisher":{"@type":"Organization","name":"デリッシュキッチン","url":"https://delishkitchen.tv"},"mainEntityOfPage":{"@type":"WebPage","@id":"https://delishkitchen.tv/recipes/482594657587429799"},"recipeCuisine":"Western","recipeCategory":"main course","cookTime":"PT1200S","prepTime":"PT0M","totalTime":"PT1200S","video":{"@type":"VideoObject","name":"ふわとろオムライス","thumbnail":"https://image.delishkitchen.tv/recipe/482594657587429799/1.jpg?version=1705849202","thumbnailUrl":"https://image.delishkitchen.tv/recipe/482594657587429799/1.jpg?version=1705849202&w=920","contentUrl":"https://media.delishkitchen.tv/recipe/482594657587429799/1.mp4","uploadDate":"2024-01-21T15:00:02Z","description":"ケチャップライスにスクランブルエッグのようにふわふわとろとろに仕上げた卵をのせるだけ♪あっという間に簡単にできるオムライスのご紹介です！卵の半熟具合はお好みで調節してお作りください！","author":{"@type":"Organization","name":"デリッシュキッチン","url":"https://delishkitchen.tv"}},"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.5","reviewCount":100,"bestRating":5,"worstRating":1},"review":[{"@type":"Review","author":{"@type":"Person","name":"まり"},"datePublished":"2024-02-19T00:21:12Z","reviewBody":"4人分をいっぺんに作りたかったのでホットプレートを使いました。 最後に 卵液を入れて 各地 自分の分にかぶせて食べてもらいます 簡単にできて美味しかったです。","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"ゴジラ博士"},"datePublished":"2024-01-28T03:35:28Z","reviewBody":"今日の昼飯に作りました。のせるだけなので簡単に作れました。また作りたいです。","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"ま"},"datePublished":"2025-06-21T15:15:26Z","reviewBody":"おいしかったです","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"いけまま"},"datePublished":"2025-05-23T05:00:26Z","reviewBody":"ランチに作りました！卵もふわふわでとても美味しかったです！家族にも好評でした！","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"つく太郎"},"datePublished":"2025-10-27T12:16:49Z","reviewBody":"ふわふわで美味しかったです！料理初心者にも作りやすかったです。","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"マハロン"},"datePublished":"2025-12-25T13:11:54Z","reviewBody":"本当はくるっと包んでみたいけど…\nかぶせるだけでも、十分美味しそうに見えます","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"ぴんくふぇありー"},"datePublished":"2025-11-27T10:43:11Z","reviewBody":"包むのが苦手なのでこれはとても助かります❣️","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"桃(火)"},"datePublished":"2025-10-02T08:23:12Z","reviewBody":"簡単にできてよかったです","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"チョコ"},"datePublished":"2026-03-01T06:59:12Z","reviewBody":"卵を乗せるのが難しかったです。\nあとは、簡単に出来ました。","reviewRating":{"@type":"Rating","ratingValue":5,"bestRating":5,"worstRating":1}},{"@type":"Review","author":{"@type":"Person","name":"ピクミン"},"datePublished":"2024-04-03T12:25:30Z","reviewBody":"卵は包まなくて良いので簡単にできました☆卵はふわとろです♪ケチャップは少し長く炒めてしまったせいか？蒸発して味が薄くなってしまった気がします。","reviewRating":{"@type":"Rating","ratingValue":4,"bestRating":5,"worstRating":1}}]}</script><script data-n-head="ssr" type="text/javascript" id="mierucajs">
