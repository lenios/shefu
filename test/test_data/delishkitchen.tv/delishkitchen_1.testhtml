e,recipe_id_str:e,tag_id:17262,tag_name:"簡単オムライス"},{recipe_id:e,recipe_id_str:e,tag_id:17698,tag_name:"晩ごはん"},{recipe_id:e,recipe_id_str:e,tag_id:18496,tag_name:h},{recipe_id:e,recipe_id_str:e,tag_id:T,tag_name:U},{recipe_id:e,recipe_id_str:e,tag_id:19910,tag_name:n}],recipe_genre:{id:aK,kind_id:433,name:"洋食"},recipe_category:{id:g,kind_id:g,name:aJ},recipe_qas:a,recipe_servings:[{recipe_id:e,recipe_id_str:e,servings:g,name:"1人分"}],recipe_steps:[{recipe_id:e,recipe_id_str:e,step:g,description:"玉ねぎはみじん切りにする。",point:c,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F1.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F1.jpg?version=1705636835"}},{recipe_id:e,recipe_id_str:e,step:2,description:"ベーコンは5mm幅に切る。",point:c,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F2.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F2.jpg?version=1705636835"}},{recipe_id:e,recipe_id_str:e,step:i,description:"ボウルに卵を割り入れ、牛乳を加えて混ぜる(卵液)。",point:c,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F3.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F3.jpg?version=1705636835"}},{recipe_id:e,recipe_id_str:e,step:C,description:"フライパンにオリーブオイルの半量(大さじ1\u002F2)を入れて熱し、玉ねぎを入れてしんなりとするまで炒める。ベーコンを加えてさっと炒める。",point:"コクのあるオムライスにしたい場合はオリーブオイルをバターに変更していただいてもおいしくいただけます。",square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F4.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F4.jpg?version=1705636835"}},{recipe_id:e,recipe_id_str:e,step:t,description:"ケチャップ(大さじ1と1\u002F2)を加えて30秒〜1分ほど炒め、ごはんを加えて炒め合わせる。塩こしょうを加えて味をととのえ、器に盛る。",point:"あたたかいごはんを使いましょう。",square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F5.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F5.jpg?version=1705636835"}},{recipe_id:e,recipe_id_str:e,step:B,description:"フライパンは洗って水気をふきとる。残りのオリーブオイル(大さじ1\u002F2)を入れて中火で熱し、卵液を流し入れる。菜箸で大きくかき混ぜながら半熟状になるまで加熱する。",point:c,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F6.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F6.jpg?version=1705636835"}},{recipe_id:e,recipe_id_str:e,step:aK,description:"5の器に卵を盛る。ケチャップをかける。",point:c,square_video:{url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F7.m3u8",poster_url:"https:\u002F\u002Fmedia.delishkitchen.tv\u002Frecipe\u002F482594657587429799\u002Fsteps\u002F7.jpg?version=1705636835"}}],nutrient:{recipe_id:e,recipe_id_str:e,items:[{name:aL,display_name:aL,icon_type:"calorie",amount:"768kcal",is_locked:b,iconComponent:"delish-icon-cooking-kcal"},{name:aM,display_name:aM,icon_type:"carbohydrate",amount:"92g",is_locked:b,iconComponent:"delish-icon-cooking-bread"},{name:aN,display_name:aN,icon_type:"lipid",amount:"31.7g",is_locked:b,iconComponent:"delish-icon-cooking-oil"},{name:"タンパク質",display_name:"たんぱく質",icon_type:"protein",amount:"22.6g",is_locked:b,iconComponent:"delish-icon-cooking-egg"},{name:aO,display_name:aO,icon_type:"saccharide",amount:"89.9g",is_locked:b,iconComponent:"delish-icon-cooking-candy"},{name:"塩分量",display_name:"塩分",icon_type:"salt",amount:"2.4g",is_locked:b,iconComponent:"delish-icon-cooking-salt"}]},banner:a},breadcrumbs:{main:[{id:i,name:O,title:a,description:a,recommended_recipe_heading:a,parents:a,children:a,representative_recipe:a,recommended_recipes:a,recipes:[{id:aP,id_str:aP,lead:"彩り豊かな♪",title:"ひき肉とナムルのピリ辛ビビンバ",description:"お手軽ナムルに、ひき肉を甘辛く