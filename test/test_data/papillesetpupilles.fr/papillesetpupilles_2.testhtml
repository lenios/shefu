											<script type="text/javascript">
											/*<![CDATA[*/
												jQuery(document).ready(function($)
												{
													$('.widget_tlb_pep2016_mr input.ingredients').tagit({
														singleFieldDelimiter: '|',
														caseSensitive: false,
														allowDuplicates: false,
														allowSpaces: true,
														placeholderText: 'Tapez ici vos ingrédients',
														onlyAllowAvailableTags: true,
														autocomplete:
														{
															source: function(request, response)
															{
																if( typeof this.options.availableTagsHasBeenLoaded === 'undefined' )
																{
																	var json_request = new XMLHttpRequest();
																	json_request.open('GET', tlb_uss_plugin_dir_url + 'ingredients.json', false);
																	json_request.send(null);

																	if( json_request.status === 200 )
																	{
																		try
																		{
																			this.options.availableTagsHasBeenLoaded = true;
																			this.options.availableTags = JSON.parse(json_request.responseText);
																		}
																		catch( error )
																		{
																			alert('Une erreur est survenue.');
																			return;
																		}
																	}
																}
																else
																{
																	console.log('Already loaded');
																}

																var regex = new RegExp(request.term, 'i');

																var results = $.map(this.options.availableTags, function(item)
																{
																	if( regex.test(item.label) )
																	{
																		return( item );
																	}
																});

																response( results );
															}
														}
													});

													var ingredients = JSON.parse('[]');

													for( ingredient in ingredients )
													{
														$('.widget_tlb_pep2016_mr input.ingredients').tagit('createTag', ingredients[ingredient], ingredient);
													}

													$('.widget_tlb_pep2016_mr form').submit(function(event)
													{
														jQuery('.widget_tlb_pep2016_mr input.ingredients').data('ui-tagit').tagInput.triggerHandler('keydown');
														jQuery('.widget_tlb_pep2016_mr input.ingredients').data('ui-tagit').tagInput.triggerHandler('blur');

														var checkboxes = $('input[type="checkbox"]:checked').map(function()
														{
															return( $(this).val() );
														});

														var tags = $('.tagit-value').map(function()
														{
															return( $(this).text() );
														});

														var terms = $.merge($.merge([], checkboxes), tags);

														terms.sort(function(a, b)
														{
															var aName = a.toLowerCase();
															var bName = b.toLowerCase();

															return( ( aName < bName ) ? -1 : (( aName > bName ) ? 1 : 0) );
														});

														var querystring = terms.join('/');
														var url = document.location.protocol + '//www.papillesetpupilles.fr/category/recettes/' + querystring + '/';

														/*window.location.href = url;

														return( false );*/

														$(this).attr('method', 'get');
														$(this).attr('action', url);
													});
												});
											/*]]>*/
											</script>
										</div>
